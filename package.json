{
  "name": "fedpromptly-desktop",
  "version": "1.0.0",
  "description": "Desktop client for FedPromptly.com",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --mac --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.fedpromptly.app",
    "productName": "FedPromptly",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!src/.*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  }
}
